# Estos correos deben crearse fuera de la app, por ejemplo en Google Workspace,
# Zoho Mail u otro proveedor de email con dominio propio.
INSTITUTIONAL_EMAIL=reflab.institucional@gmail.com
SUPPORT_EMAIL=reflab.institucional@gmail.com

# Resend debe configurarse en Vercel o en el proveedor de despliegue.
# No hardcodear esta clave en el codigo.
RESEND_API_KEY=

# Mientras no haya dominio verificado en Resend, usar el remitente de prueba.
# Cuando el dominio reflab.app este verificado, se puede cambiar por institucional@reflab.app.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Proveedor de email. Usar "smtp" para Gmail/Google Workspace y "resend" para Resend.
EMAIL_PROVIDER=smtp

# SMTP para Gmail. SMTP_PASSWORD debe ser una clave de aplicacion de Google,
# no la contrasena normal de la cuenta.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=reflab.institucional@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=reflab.institucional@gmail.com

# URL publica de la app, usada en emails transaccionales.
APP_URL=https://reflab.app

# Emails separados por coma que deben sincronizarse como super_admin al entrar.
REFLAB_SUPER_ADMIN_EMAILS=

# Firebase Cloud Messaging para notificaciones push web.
# Las NEXT_PUBLIC_* se usan en el navegador. Las FIREBASE_* se usan en el servidor.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Secreto opcional para proteger /api/notifications/scheduled cuando lo llama Vercel Cron.
CRON_SECRET=
